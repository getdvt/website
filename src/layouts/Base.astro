---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'dvt — Dashboards as Versioned JSON Specs',
  description = 'Dashboards as data. AI-native, fully-customizable, open dashboarding platform — dashboards as versioned JSON specs.',
  ogImage = '/og-image.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "name": "dvt",
          "url": "https://dvt.dev",
          "logo": "https://dvt.dev/logo.svg",
          "description": "Open, AI-native dashboarding platform — dashboards as versioned JSON specs.",
          "sameAs": ["https://github.com/getdvt/dvt"]
        },
        {
          "@type": "SoftwareApplication",
          "name": "dvt",
          "url": "https://dvt.dev",
          "applicationCategory": "BusinessApplication",
          "operatingSystem": "Web",
          "description": "Open dashboarding platform where every dashboard is a versioned JSON spec — authored by humans and AI agents alike via REST API or MCP.",
          "license": "https://opensource.org/licenses/Apache-2.0",
          "offers": {
            "@type": "Offer",
            "price": "0",
            "priceCurrency": "USD",
            "description": "Free to self-host"
          }
        }
      ]
    })} />

    <!--
      Cloudflare Web Analytics beacon.
      TOKEN is injected via a Cloudflare Pages environment variable: CF_BEACON_TOKEN.
      The beacon has no cookies and requires no consent banner.
      Set CF_BEACON_TOKEN in the Pages project → Settings → Environment variables.
    -->
    {import.meta.env.CF_BEACON_TOKEN && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${import.meta.env.CF_BEACON_TOKEN}"}`}
      />
    )}
  </head>
  <body>
    <slot />
  </body>
</html>
