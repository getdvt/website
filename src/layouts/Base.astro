---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  /** Page-specific schema.org node(s) appended to the global @graph (e.g. BlogPosting, BreadcrumbList). */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = 'dvt — Dashboards as Versioned JSON Specs',
  description = 'Dashboards as data. AI-native, fully-customizable, open data viz tool — dashboards as versioned JSON specs.',
  ogImage = '/og-image.png',
  jsonLd,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);

// Global site entities, always present. Pages may append their own nodes
// (BlogPosting, BreadcrumbList, …) via the `jsonLd` prop.
const graph: Record<string, unknown>[] = [
  {
    "@type": "Organization",
    "@id": "https://dvt.dev/#organization",
    "name": "dvt",
    "url": "https://dvt.dev",
    "logo": "https://dvt.dev/logo.svg",
    "description": "Open, AI-native data viz tool — dashboards as versioned JSON specs."
  },
  {
    "@type": "SoftwareApplication",
    "name": "dvt",
    "url": "https://dvt.dev",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "description": "Open data viz tool where every dashboard is a versioned JSON spec — authored by humans and AI agents alike via REST API or MCP."
  },
  ...(jsonLd ? [jsonLd].flat() : []),
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Mark JS-capable clients so progressive-enhancement reveals only hide
         content when JS can bring it back. -->
    <script is:inline>document.documentElement.classList.add('js');</script>
    <link rel="canonical" href={canonicalURL} />

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- RSS autodiscovery -->
    <link rel="alternate" type="application/rss+xml" title="dvt blog" href="/rss.xml" />

    <!-- Structured data. Escape `<` to < so a `</script>` substring in any
         field (e.g. a post title) can't break out of the script block. -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": graph
    }).replace(/</g, '\\u003c')} />

    <!--
      Cloudflare Web Analytics beacon.
      TOKEN is injected via a Cloudflare Pages environment variable: CF_BEACON_TOKEN.
      The beacon has no cookies and requires no consent banner.
      Set CF_BEACON_TOKEN in the Pages project → Settings → Environment variables.
    -->
    {import.meta.env.CF_BEACON_TOKEN && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${import.meta.env.CF_BEACON_TOKEN}"}`}
      />
    )}
  </head>
  <body>
    <slot />
  </body>
</html>
