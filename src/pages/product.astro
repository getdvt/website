---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Handraise from '../components/Handraise.astro';
import Footer from '../components/Footer.astro';
import VersionHistoryMock from '../components/product/VersionHistoryMock.astro';
import CommentThreadMock from '../components/product/CommentThreadMock.astro';
import SkillsMock from '../components/product/SkillsMock.astro';

export const prerender = true;

const DEMO_URL = 'https://demo.dvt.dev';

// "More ways teams work in dvt": secondary shipped features.
const more = [
  { icon: '⤓', title: 'Scheduled exports', body: 'Subscribe a dashboard, page, or single panel to recurring PDF/PNG exports: delivered on a schedule to email, Slack, Teams, or Google Chat.' },
  { icon: '◐', title: 'White-label & dark mode', body: 'Set your product name, accent, and logo; pick a default appearance. Each viewer gets their own light / dark / system toggle over your org theme.' },
  { icon: '☰', title: 'Folders & favorites', body: 'Organize dashboards into shareable folders with inherited access, and star the ones you live in so they surface first on your home screen.' },
  { icon: '◆', title: 'Agent attribution', body: 'Every edit records whether a human, an agent, or the system made it, and which API key an agent acted through. Nothing an AI does is anonymous.' },
  { icon: '✓', title: 'Preview before apply', body: 'Every write (human or AI) can be previewed first: validate the spec, compute the result, show the change, then persist. The AI shows its work before it makes it.' },
  { icon: '❝', title: 'Built-in doc layer', body: 'Panels carry their own intent, assumptions, and the exact query that built them. The documentation travels inside the spec, not in a stale wiki.' },
];
---

<Base
  title="dvt Product — version control, review, and org knowledge for AI-built dashboards"
  description="dvt gives every dashboard native version control with visual diffs, panel-anchored comments that drive a human-plus-AI review loop, and an org knowledge layer AI agents read at build time, plus scheduled exports, white-label branding, and full agent attribution."
>
  <Nav />
  <main>
    <!-- Page hero -->
    <section class="page-hero">
      <div class="container">
        <div class="eyebrow">Product</div>
        <h1>Every change is reviewable, revertible, and attributed.</h1>
        <p class="lead">
          Because a dvt dashboard is a versioned spec, not a pile of clicks, the product ships the
          workflow that BI has always been missing: native version control with visual diffs,
          comments that a human and an AI can pass back and forth, and an org knowledge layer every
          AI build reads first.
        </p>
        <div class="hero-cta-row">
          <a href={DEMO_URL} class="hero-cta-primary">Explore the demo app →</a>
          <a href="/#early-access" class="hero-cta-secondary">Get early access</a>
        </div>
      </div>
    </section>

    <!-- Version control & visual diffs -->
    <section id="history" class="section feat" data-reveal>
      <div class="container feat-row">
        <div class="feat-copy">
          <span class="kicker">Version control</span>
          <h2>Every save is a version. Every version has a diff.</h2>
          <p>
            Every change, to a dashboard, a page, even a single element, gets an append-only
            revision. The History pane shows who changed what, with the change note and a
            before → after thumbnail for each version.
          </p>
          <ul class="feat-list">
            <li><strong>Visual diffs.</strong> A pixel-level compare highlights exactly which regions moved: the AI's "did my edit do what I meant?" check, and yours.</li>
            <li><strong>Identity-preserving restore.</strong> Roll back to any version; child elements keep their identity so later edits stay correct.</li>
            <li><strong>Full attribution.</strong> Human, agent, or system, plus which key an agent used.</li>
          </ul>
        </div>
        <div class="feat-visual">
          <VersionHistoryMock />
        </div>
      </div>
    </section>

    <!-- Human ⇄ AI review -->
    <section id="review" class="section section-alt feat" data-reveal>
      <div class="container feat-row reverse">
        <div class="feat-copy">
          <span class="kicker">Human ⇄ AI review</span>
          <h2>Comment on a dashboard. Let Claude fix it.</h2>
          <p>
            Leave a threaded comment, pinned to a specific panel or the whole dashboard. An AI agent
            reads the open threads over MCP, makes the requested edits, replies, and resolves. The
            review loop humans expect from code, now for the dashboard itself.
          </p>
          <ul class="feat-list">
            <li><strong>Anchored threads.</strong> A comment knows which panel it's about: by name, even after the panel is renamed.</li>
            <li><strong>One-click handoff.</strong> "Open Claude" launches your agent straight into the open review queue.</li>
            <li><strong>Everyone can review.</strong> Comment and resolve sit at the viewer floor: reviewers don't need edit rights.</li>
          </ul>
        </div>
        <div class="feat-visual">
          <CommentThreadMock />
        </div>
      </div>
    </section>

    <!-- Org knowledge / Skills -->
    <section id="skills" class="section feat" data-reveal>
      <div class="container feat-row">
        <div class="feat-copy">
          <span class="kicker">Org knowledge</span>
          <h2>Teach dvt how your team builds, once.</h2>
          <p>
            Skills are org-scoped, versioned authoring docs: your metric definitions, warehouse
            semantics, and "how we build charts here." AI agents read the relevant ones before
            authoring, so every generated dashboard follows house rules, not generic defaults.
          </p>
          <ul class="feat-list">
            <li><strong>Author once, apply everywhere.</strong> Humans write skills in-app or let an agent draft them: both write the same versioned record.</li>
            <li><strong>Read at build time.</strong> Agents discover and load skills over MCP before they author.</li>
            <li><strong>Different from the download.</strong> The public <a href="/spec">spec-authoring skill</a> teaches any harness the format; org skills teach it <em>your</em> conventions.</li>
          </ul>
        </div>
        <div class="feat-visual">
          <SkillsMock />
        </div>
      </div>
    </section>

    <!-- More ways teams work in dvt -->
    <section class="section section-alt" data-reveal>
      <div class="container">
        <h2 class="band-title">More ways teams work in dvt</h2>
        <p class="band-sub">The workflow around the dashboard. Not just the picture.</p>
        <div class="more-grid">
          {more.map((f) => (
            <div class="more-card">
              <div class="more-icon">{f.icon}</div>
              <div>
                <h3>{f.title}</h3>
                <p>{f.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <Handraise />
  </main>
  <Footer />
</Base>

<script>
  import '../scripts/reveal.ts';
</script>

<style>
  .page-hero {
    padding: var(--space-16) 0 var(--space-12);
    border-bottom: 1px solid var(--color-neutral-200);
  }
  .eyebrow {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-brand-mark);
    margin-bottom: var(--space-4);
  }
  .page-hero h1 {
    font-size: clamp(var(--text-3xl), 5vw, 56px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-neutral-900);
    margin-bottom: var(--space-5);
    max-width: 760px;
  }
  .lead {
    font-size: var(--text-lg);
    color: var(--color-neutral-600);
    line-height: 1.65;
    max-width: 660px;
  }

  .section { padding: var(--space-section) 0; }
  .section-alt {
    background: var(--color-neutral-50);
    border-top: 1px solid var(--color-neutral-200);
    border-bottom: 1px solid var(--color-neutral-200);
  }

  /* Feature rows: copy + visual, alternating sides */
  .feat-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }
  .feat-row.reverse .feat-copy { order: 2; }
  .feat-row.reverse .feat-visual { order: 1; }

  .kicker {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-brand-mark);
  }
  .feat-copy h2 {
    font-size: clamp(var(--text-2xl), 3.5vw, var(--text-4xl));
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-neutral-900);
    margin: var(--space-3) 0 var(--space-4);
  }
  .feat-copy > p {
    font-size: var(--text-base);
    color: var(--color-neutral-600);
    line-height: 1.7;
    margin-bottom: var(--space-5);
  }
  .feat-list { list-style: none; margin: 0; padding: 0; display: grid; gap: var(--space-3); }
  .feat-list li {
    position: relative;
    padding-left: var(--space-6);
    font-size: var(--text-sm);
    color: var(--color-neutral-600);
    line-height: 1.6;
  }
  .feat-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 8px;
    height: 8px;
    border-radius: 2px;
    background: var(--color-brand-mark);
  }
  .feat-list strong { color: var(--color-neutral-900); font-weight: 600; }
  .feat-list a { color: var(--color-brand-navy); font-weight: 600; }
  .feat-list a:hover { color: var(--color-brand-mark); }

  /* Band headings */
  .band-title {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-neutral-900);
    margin-bottom: var(--space-2);
  }
  .band-sub {
    font-size: var(--text-sm);
    color: var(--color-neutral-500);
    margin-bottom: var(--space-8);
  }

  /* More grid */
  .more-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-5);
  }
  .more-card {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
    padding: var(--space-5);
    background: var(--color-white);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-lg);
  }
  .more-icon {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    color: var(--color-brand-mark);
    background: rgba(91, 191, 186, 0.1);
    border-radius: var(--radius-md);
  }
  .more-card h3 {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-neutral-900);
    margin-bottom: 4px;
  }
  .more-card p {
    font-size: var(--text-sm);
    color: var(--color-neutral-600);
    line-height: 1.6;
  }

  /* Hero CTAs (shared pattern with /spec) */
  .hero-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }
  .hero-cta-primary {
    display: inline-flex;
    align-items: center;
    padding: 12px var(--space-6);
    background: var(--color-brand-navy);
    color: var(--color-white);
    border-radius: var(--radius-md);
    font-size: var(--text-base);
    font-weight: 600;
    transition: background var(--transition-fast);
  }
  .hero-cta-primary:hover { background: var(--color-neutral-700); color: var(--color-white); }
  .hero-cta-secondary {
    display: inline-flex;
    align-items: center;
    padding: 12px var(--space-6);
    background: transparent;
    color: var(--color-neutral-700);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-md);
    font-size: var(--text-base);
    font-weight: 500;
    transition: border-color var(--transition-fast), color var(--transition-fast);
  }
  .hero-cta-secondary:hover { border-color: var(--color-neutral-400); color: var(--color-neutral-950); }

  @media (max-width: 820px) {
    .feat-row { grid-template-columns: 1fr; gap: var(--space-8); }
    .feat-row.reverse .feat-copy { order: 1; }
    .feat-row.reverse .feat-visual { order: 2; }
  }
</style>
