---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Handraise from '../components/Handraise.astro';
import Footer from '../components/Footer.astro';
import SpecPlayground from '../components/SpecPlayground.astro';
import ChartCarousel from '../components/ChartCarousel.astro';
import ChartGallery from '../components/ChartGallery.astro';
import { totalChartCount } from '../data/charts';

export const prerender = true;

// The dvt app hosts the live Spec Builder: the open, backend-free demo at
// demo.dvt.dev (app.dvt.dev is reserved for the eventual authenticated product).
const BUILDER_URL = 'https://demo.dvt.dev/builder';

// Rich-table vocabulary: the `table` element is dvt Core (computed client-side
// over already-bound rows; never a re-query, never a re-bill).
const tableFeatures = [
  { title: 'Conditional formatting', body: 'A real predicate grammar (eq / gt / between / in / topN / bottomN, cross-column references, and any/all combinators) styling a cell or a whole row.' },
  { title: 'Colour-scale heatmaps', body: 'Continuous per-column encoding: numeric, quantile, or binned, over named ramps (blues, viridis, rdbu…) with an auto or fixed domain.' },
  { title: 'In-cell visualizations', body: 'Sparklines, data bars, bullet bars, win/loss strips, dots, icons, and images, rendered inside the cell, driven by sibling columns.' },
  { title: 'Grouping & subtotals', body: 'Nested row groups with per-group subtotals and a grand total, collapsible from the header. No pivot required.' },
  { title: 'Pivot / cross-tab', body: 'Rows × columns cross-tabs with sum / weighted-average aggregation, generated value columns, and row/column/grand totals.' },
  { title: 'Spanning headers', body: 'Multi-row grouped column headers so a wide cross-tab reads as "FY26 revenue → Q1 · Q2 · Q3", not a flat wall of columns.' },
  { title: 'Resizable, wrapping columns', body: 'Drag a column border to resize (40–1200px); wrap long text over multiple lines with a show-more toggle. Sort and filter per column.' },
  { title: 'Warehouse-comment headers', body: 'Pull column headers and tooltips straight from your warehouse COMMENT metadata: the table documents itself from the source.' },
];

// Interactions: filters, cross-filter, drill, and declarative context menus.
const interactions = [
  { icon: '⛃', title: 'Filters', body: '12 control kinds (select, multiselect, date-range, number-range, search, toggle, number, segmented, radio, button-group, checkbox-list, top-N), bound to named SQL parameters, never string-interpolated.' },
  { icon: '⬚', title: 'Cross-filter (brush)', body: 'Drag-select a region of a chart to filter (or just highlight) every other panel on the page.' },
  { icon: '↳', title: 'Drill down', body: 'Right-click a datapoint to navigate to a detail page with the clicked value bound as a parameter.' },
  { icon: '☰', title: 'Context menus', body: 'Declarative right-click actions (filter, drill, open link, copy, export, or open an overlay), templated from the clicked row. No code.' },
  { icon: '▧', title: 'Overlays', body: 'Present a target page as a modal or drawer without leaving the dashboard: a superset of drill-down.' },
  { icon: '◷', title: 'Relative dates', body: 'Timezone-aware presets (last 7d, 30d, MTD, QTD, YTD, all-time), resolved at view time.' },
];

const features = [
  { icon: '◑', title: 'Themes & tokens', body: 'Every visual property, down to the gap between an axis and its title, is a named, storable token. Org and dashboard themes cascade.' },
  { icon: '⊞', title: 'Metric KPIs', body: 'Stat panels with currency/percent formatting, period comparisons, deltas, and inline sparklines. Declared, not configured by hand.' },
  { icon: '⚡', title: 'AI authoring via MCP', body: 'Claude POSTs a valid spec through the dvt MCP server and the dashboard appears: no GUI clicks, no screenshots, no pasted JSON.' },
  { icon: '✓', title: 'Validate → preview → apply', body: 'Validate any spec before saving, preview changes before applying. Same spec → same pixels, deterministically, every time.' },
  { icon: '◉', title: 'Geo & maps', body: 'Choropleths and geographic flows over bundled USA / world boundaries, or drive geography straight from a GeoJSON column.' },
  { icon: '❝', title: 'Built-in doc layer', body: 'Panels carry their own intent, assumptions, and the exact query that built them: the documentation travels inside the spec.' },
];
---

<Base
  title="The dvt JSON Dashboard Spec: open format, REST API + MCP"
  description="Every dvt dashboard is a versioned JSON spec: stored as a database record, updated via REST API or MCP, authored by humans and AI agents alike. 30+ chart and table types. Open format."
>
  <Nav />
  <main>
    <!-- Page hero -->
    <section class="page-hero">
      <div class="container">
        <div class="eyebrow">Spec</div>
        <h1>A dashboard is a JSON document.</h1>
        <p class="lead">
          Every dvt dashboard (its theme, layout, panels, and visual properties)
          lives as a versioned JSON spec in dvt's database. Update it via API or MCP call.
          No deploy pipeline for a chart color change.
        </p>
        <div class="hero-cta-row">
          <a href={BUILDER_URL} class="hero-cta-primary">Open the live builder →</a>
          <a href="/dvt-spec-authoring-skill.md" class="hero-cta-secondary" download>Download the AI authoring skill</a>
        </div>
        <p class="hero-cta-note">
          Edit the raw JSON and watch it render, like Slack's Block Kit Builder, for dashboards.
          Bring your own AI: the skill teaches any harness to write dvt specs.
        </p>
      </div>
    </section>

    <!-- Live spec ⇄ render playground -->
    <section class="section pg-section">
      <div class="container">
        <div class="section-head">
          <span class="kicker">Edit the spec, watch it render</span>
          <h2>Left is the source of truth. Right is what ships.</h2>
          <p>The whole dashboard is the JSON on the left: flip between examples and see the same engine dvt ships render it live.</p>
        </div>
        <SpecPlayground />
      </div>
    </section>

    <!-- DAD concept -->
    <section class="section section-alt" data-reveal>
      <div class="container">
        <h2 class="band-title">Dashboards as Data (DAD)</h2>
        <div class="dad-grid">
          <div class="dad-item">
            <div class="dad-icon">◎</div>
            <h3>Live, not deployed</h3>
            <p>Dashboard specs are database records: update one via REST API or MCP and it's live instantly. dvt tracks every revision server-side. Export to git if you want GitOps; it's never required.</p>
          </div>
          <div class="dad-item">
            <div class="dad-icon">⚡</div>
            <h3>AI-authored</h3>
            <p>Claude can POST a valid spec to the dvt MCP server and the dashboard appears: no GUI clicks, no screenshots, no copy-pasting JSON by hand.</p>
          </div>
          <div class="dad-item">
            <div class="dad-icon">⊞</div>
            <h3>Fully customizable</h3>
            <p>Every visual property, down to the gap between an axis and its title, is a named, storable parameter in the spec. Nothing is locked by the tool.</p>
          </div>
          <div class="dad-item">
            <div class="dad-icon">✓</div>
            <h3>Deterministic</h3>
            <p>Same spec → same pixels, every time. Validate a spec before saving it. Preview changes before applying them. AI agents get a preview loop before persisting.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Chart showcase: carousel + gallery -->
    <section class="section gallery-section">
      <div class="container">
        <div class="section-head" data-reveal>
          <span class="kicker">One format, {totalChartCount}+ visual types</span>
          <h2>Every chart is a few lines of spec.</h2>
          <p>
            From a bar chart to an animated chart race, from sankey flows to cohort heat tables:
            the same declarative JSON describes them all. No imperative drawing code in the authoring surface.
          </p>
        </div>

        <div data-reveal>
          <ChartCarousel />
        </div>

        <div class="gallery-wrap" data-reveal>
          <ChartGallery />
        </div>
      </div>
    </section>

    <!-- Rich tables -->
    <section class="section" data-reveal>
      <div class="container">
        <div class="section-head">
          <span class="kicker">Tables are a first-class visual</span>
          <h2>A table in dvt is not just rows and columns.</h2>
          <p>
            The <code>table</code> element carries a full presentation vocabulary: all of it declared
            in the spec, all of it dvt Core, all computed client-side over rows you already fetched.
          </p>
        </div>
        <div class="feature-grid">
          {tableFeatures.map((f) => (
            <div class="feature feature--compact">
              <div>
                <h3>{f.title}</h3>
                <p>{f.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Interactions -->
    <section class="section section-alt" data-reveal>
      <div class="container">
        <h2 class="band-title">Interactive, not just rendered</h2>
        <p class="band-sub">Filters, cross-filtering, drill-downs, and context menus. Declared in the spec, no imperative event code.</p>
        <div class="feature-grid">
          {interactions.map((f) => (
            <div class="feature">
              <div class="feature-icon">{f.icon}</div>
              <div>
                <h3>{f.title}</h3>
                <p>{f.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Feature strip -->
    <section class="section" data-reveal>
      <div class="container">
        <h2 class="band-title">More than charts</h2>
        <p class="band-sub">The spec carries everything a dashboard needs. Not just the picture.</p>
        <div class="feature-grid">
          {features.map((f) => (
            <div class="feature">
              <div class="feature-icon">{f.icon}</div>
              <div>
                <h3>{f.title}</h3>
                <p>{f.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Schema note -->
    <section class="section" data-reveal>
      <div class="container schema-note">
        <h2>Open spec, published schema</h2>
        <p>
          The dvt spec format is Apache-2.0 licensed, and a published JSON Schema is
          on the way, enabling validation, editor autocompletion, and AI self-correction
          without needing to query a running server. The spec travels with your data,
          not with dvt's infrastructure.
        </p>
        <p>
          The schema is in active design. The examples above reflect the current working
          draft: field names and structure may shift before v1.
        </p>
        <a href="/#early-access" class="btn-access-inline">Follow the build →</a>
      </div>
    </section>

    <Handraise />
  </main>
  <Footer />
</Base>

<script>
  import '../scripts/charts.ts';
  import '../scripts/reveal.ts';
</script>

<style>
  .page-hero {
    padding: var(--space-16) 0 var(--space-12);
    border-bottom: 1px solid var(--color-neutral-200);
  }

  .eyebrow {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-brand-mark);
    margin-bottom: var(--space-4);
  }

  .page-hero h1 {
    font-size: clamp(var(--text-3xl), 5vw, 56px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-neutral-900);
    margin-bottom: var(--space-5);
    max-width: 700px;
  }

  .lead {
    font-size: var(--text-lg);
    color: var(--color-neutral-600);
    line-height: 1.65;
    max-width: 600px;
  }

  .section { padding: var(--space-section) 0; }
  .section-alt {
    padding: var(--space-section) 0;
    background: var(--color-neutral-50);
    border-top: 1px solid var(--color-neutral-200);
    border-bottom: 1px solid var(--color-neutral-200);
  }

  .pg-section { padding-top: var(--space-12); }

  /* Section heads */
  .section-head { max-width: 640px; margin-bottom: var(--space-8); }
  .kicker {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-brand-mark);
  }
  .section-head h2 {
    font-size: clamp(var(--text-2xl), 3.5vw, var(--text-4xl));
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-neutral-900);
    margin: var(--space-3) 0 var(--space-3);
  }
  .section-head p {
    font-size: var(--text-base);
    color: var(--color-neutral-600);
    line-height: 1.65;
  }
  .band-title {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-neutral-900);
    margin-bottom: var(--space-2);
  }
  .band-sub {
    font-size: var(--text-sm);
    color: var(--color-neutral-500);
    margin-bottom: var(--space-8);
  }

  /* DAD grid */
  .dad-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-6);
    margin-top: var(--space-8);
  }
  .dad-item {
    padding: var(--space-8);
    background: var(--color-white);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-lg);
  }
  .dad-icon {
    font-size: 20px;
    margin-bottom: var(--space-3);
    color: var(--color-brand-mark);
  }
  .dad-item h3 {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-neutral-900);
    margin-bottom: var(--space-2);
  }
  .dad-item p {
    font-size: var(--text-sm);
    color: var(--color-neutral-600);
    line-height: 1.6;
  }

  /* Gallery section spacing */
  .gallery-wrap { margin-top: var(--space-12); }

  /* Feature strip */
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-5);
  }
  .feature {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
    padding: var(--space-5);
    background: var(--color-white);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-lg);
  }
  .feature-icon {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    color: var(--color-brand-mark);
    background: rgba(91, 191, 186, 0.1);
    border-radius: var(--radius-md);
  }
  .feature h3 {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-neutral-900);
    margin-bottom: 4px;
  }
  .feature p {
    font-size: var(--text-sm);
    color: var(--color-neutral-600);
    line-height: 1.6;
  }

  /* Schema note */
  .schema-note { max-width: 640px; }
  .schema-note h2 {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-neutral-900);
    margin-bottom: var(--space-5);
  }
  .schema-note p {
    color: var(--color-neutral-600);
    line-height: 1.7;
    margin-bottom: var(--space-4);
    font-size: var(--text-sm);
  }
  .btn-access-inline {
    display: inline-flex;
    align-items: center;
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-brand-navy);
    transition: color var(--transition-fast);
  }
  .btn-access-inline:hover { color: var(--color-brand-mark); }

  /* Hero CTAs */
  .hero-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }
  .hero-cta-primary {
    display: inline-flex;
    align-items: center;
    padding: 12px var(--space-6);
    background: var(--color-brand-navy);
    color: var(--color-white);
    border-radius: var(--radius-md);
    font-size: var(--text-base);
    font-weight: 600;
    transition: background var(--transition-fast);
  }
  .hero-cta-primary:hover { background: var(--color-neutral-700); color: var(--color-white); }
  .hero-cta-secondary {
    display: inline-flex;
    align-items: center;
    padding: 12px var(--space-6);
    background: transparent;
    color: var(--color-neutral-700);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-md);
    font-size: var(--text-base);
    font-weight: 500;
    transition: border-color var(--transition-fast), color var(--transition-fast);
  }
  .hero-cta-secondary:hover { border-color: var(--color-neutral-400); color: var(--color-neutral-950); }
  .hero-cta-note {
    margin-top: var(--space-4);
    color: var(--color-neutral-600);
    font-size: var(--text-sm);
    line-height: 1.7;
    max-width: 48ch;
  }
</style>
