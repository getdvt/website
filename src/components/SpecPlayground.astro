---
import { Code } from 'astro:components';
import EChart from './EChart.astro';

const FONT = 'Inter, -apple-system, BlinkMacSystemFont, sans-serif';
const axisLabel = { color: '#A1A1AA', fontSize: 11, fontFamily: FONT };
const splitLine = { lineStyle: { color: '#F4F4F5' } };
const baseAxisLine = { lineStyle: { color: '#E4E4E7' } };
const grid = { left: 6, right: 16, top: 22, bottom: 4, containLabel: true };
const tooltip = { trigger: 'axis', backgroundColor: '#18181B', borderColor: '#27272A', textStyle: { color: '#FAFAFA', fontSize: 11, fontFamily: FONT } };

const presets = [
  {
    id: 'bar',
    label: 'Bar chart',
    spec: `{
  "schemaVersion": 1,
  "meta": { "title": "Monthly Revenue" },
  "theme": { "tokens": { "semantic": {
    "chart.series.1": "#4F46E5"
  } } },
  "panels": [{
    "id": "rev",
    "type": "chart:bar",
    "title": "Monthly Revenue",
    "data": {
      "sourceId": "warehouse-prod",
      "query": "SELECT month, SUM(revenue) AS revenue\\n               FROM analytics.sales GROUP BY month"
    },
    "spec": {
      "xAxis": { "type": "category", "name": "Month" },
      "yAxis": { "type": "value", "name": "Revenue ($k)" },
      "series": [{ "type": "bar", "barMaxWidth": 48 }]
    }
  }]
}`,
    option: {
      color: ['#4F46E5'], textStyle: { fontFamily: FONT }, grid, tooltip,
      xAxis: { type: 'category', data: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'], name: 'Month', nameTextStyle: axisLabel, axisLabel, axisLine: baseAxisLine, axisTick: { show: false } },
      yAxis: { type: 'value', name: 'Revenue ($k)', nameTextStyle: axisLabel, axisLabel, splitLine, axisLine: { show: false }, axisTick: { show: false } },
      series: [{ type: 'bar', data: [120, 150, 178, 168, 212, 264], barMaxWidth: 40, itemStyle: { color: '#4F46E5', borderRadius: [4, 4, 0, 0] } }],
    },
  },
  {
    id: 'area',
    label: 'Trend + area',
    spec: `{
  "schemaVersion": 1,
  "meta": { "title": "Weekly Active Users" },
  "panels": [{
    "id": "wau",
    "type": "chart:area",
    "title": "Weekly Active Users",
    "data": { "metricRef": "metric.wau.weekly_series" },
    "spec": {
      "series": [{
        "type": "line",
        "smooth": true,
        "areaStyle": {}
      }]
    }
  }]
}`,
    option: {
      color: ['#4F46E5'], textStyle: { fontFamily: FONT }, grid, tooltip,
      xAxis: { type: 'category', data: ['W1', 'W2', 'W3', 'W4', 'W5', 'W6', 'W7', 'W8'], boundaryGap: false, axisLabel, axisLine: baseAxisLine, axisTick: { show: false } },
      yAxis: { type: 'value', axisLabel, splitLine, axisLine: { show: false }, axisTick: { show: false } },
      series: [{
        type: 'line', smooth: true, showSymbol: false, data: [3200, 3650, 3500, 4120, 4480, 4310, 4820, 5240],
        lineStyle: { width: 2.5, color: '#4F46E5' },
        areaStyle: { color: { type: 'linear', x: 0, y: 0, x2: 0, y2: 1, colorStops: [{ offset: 0, color: 'rgba(79,70,229,0.26)' }, { offset: 1, color: 'rgba(79,70,229,0)' }] } },
      }],
    },
  },
  {
    id: 'funnel',
    label: 'Funnel',
    spec: `{
  "schemaVersion": 1,
  "meta": {
    "title": "Signup Funnel",
    "createdBy": { "actorType": "agent", "actorId": "claude-opus" }
  },
  "panels": [{
    "id": "funnel",
    "type": "chart:funnel",
    "title": "Conversion Funnel",
    "data": { "metricRef": "metric.funnel.signup_to_paid_30d" },
    "spec": {
      "steps": ["Signup", "Activated", "Trial", "Paid"],
      "series": [{ "type": "funnel", "label": { "show": true } }]
    }
  }]
}`,
    option: {
      color: ['#4F46E5'], textStyle: { fontFamily: FONT }, tooltip: { ...tooltip, trigger: 'item' },
      series: [{
        type: 'funnel', left: 8, right: 8, top: 14, bottom: 14, minSize: '26%', gap: 2,
        label: { show: true, position: 'inside', color: '#fff', fontFamily: FONT, fontSize: 12, fontWeight: 600 },
        data: [
          { value: 100, name: 'Signup', itemStyle: { color: '#4F46E5' } },
          { value: 62, name: 'Activated', itemStyle: { color: '#818CF8' } },
          { value: 24, name: 'Trial', itemStyle: { color: '#5B9BD5' } },
          { value: 8, name: 'Paid', itemStyle: { color: '#16263A' } },
        ],
      }],
    },
  },
];
---

<div class="playground" data-playground>
  <div class="pg-tabs" role="tablist" aria-label="Spec examples">
    {presets.map((p, i) => (
      <button class={`pg-tab${i === 0 ? ' active' : ''}`} data-pgtab={p.id} type="button" role="tab" aria-selected={i === 0 ? 'true' : 'false'}>
        {p.label}
      </button>
    ))}
  </div>

  <div class="pg-body">
    <div class="pg-code">
      <div class="pg-pane-label"><span class="dot-row"><i></i><i></i><i></i></span> dashboard.json</div>
      {presets.map((p, i) => (
        <div class={`pg-code-pane${i === 0 ? ' active' : ''}`} data-pgcode={p.id} hidden={i !== 0}>
          <Code code={p.spec} lang="json" theme="github-dark" />
        </div>
      ))}
    </div>

    <div class="pg-render">
      <div class="pg-pane-label"><span class="live-dot"></span> Renders as — live ECharts</div>
      <div class="pg-render-stage">
        {presets.map((p, i) => (
          <div class={`pg-render-pane${i === 0 ? ' active' : ''}`} data-pgrender={p.id} hidden={i !== 0}>
            <EChart option={p.option} height="300px" label={`${p.label} preview`} />
          </div>
        ))}
      </div>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>('[data-playground]').forEach((root) => {
    const tabs = [...root.querySelectorAll<HTMLElement>('[data-pgtab]')];
    const codes = [...root.querySelectorAll<HTMLElement>('[data-pgcode]')];
    const renders = [...root.querySelectorAll<HTMLElement>('[data-pgrender]')];
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const id = tab.dataset.pgtab;
        tabs.forEach((t) => {
          const on = t === tab;
          t.classList.toggle('active', on);
          t.setAttribute('aria-selected', on ? 'true' : 'false');
        });
        codes.forEach((c) => { const on = c.dataset.pgcode === id; c.classList.toggle('active', on); c.hidden = !on; });
        renders.forEach((r) => { const on = r.dataset.pgrender === id; r.classList.toggle('active', on); r.hidden = !on; });
        requestAnimationFrame(() => window.dvtChartsScan?.());
      });
    });
  });
</script>

<style>
  .playground {
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-white);
    box-shadow: var(--shadow-md);
  }
  .pg-tabs {
    display: flex;
    gap: var(--space-1);
    padding: var(--space-3) var(--space-3) 0;
    background: var(--color-neutral-950);
    border-bottom: 1px solid var(--color-neutral-800);
    overflow-x: auto;
  }
  .pg-tab {
    padding: 8px var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-neutral-400);
    background: transparent;
    border: none;
    border-radius: var(--radius-sm) var(--radius-sm) 0 0;
    cursor: pointer;
    white-space: nowrap;
    transition: color var(--transition-fast), background var(--transition-fast);
  }
  .pg-tab:hover { color: var(--color-neutral-200); }
  .pg-tab.active {
    color: var(--color-white);
    background: var(--color-neutral-900);
  }

  .pg-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }
  @media (max-width: 820px) {
    .pg-body { grid-template-columns: 1fr; }
  }

  .pg-pane-label {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.04em;
    padding: var(--space-3) var(--space-4);
  }
  .pg-code { background: var(--color-neutral-950); }
  .pg-code .pg-pane-label { color: var(--color-neutral-500); }
  .dot-row { display: inline-flex; gap: 4px; }
  .dot-row i { width: 8px; height: 8px; border-radius: 50%; background: var(--color-neutral-700); }

  .pg-code-pane :global(pre) {
    margin: 0;
    padding: 0 var(--space-4) var(--space-4);
    background: transparent !important;
    font-size: 11.5px;
    line-height: 1.6;
    max-height: 340px;
    overflow: auto;
  }

  .pg-render {
    border-left: 1px solid var(--color-neutral-200);
    display: flex;
    flex-direction: column;
  }
  @media (max-width: 820px) {
    .pg-render { border-left: none; border-top: 1px solid var(--color-neutral-200); }
  }
  .pg-render .pg-pane-label { color: var(--color-neutral-400); }
  .live-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--color-brand-mark);
    animation: pg-pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  @keyframes pg-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }

  .pg-render-stage { flex: 1; padding: var(--space-3) var(--space-4) var(--space-4); }
  .pg-render-pane[hidden] { display: none; }
</style>
