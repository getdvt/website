---
// Nav: logo (left) + GitHub star link (right)
// Logo SVG is inline so it renders correctly before fonts load.
---

<nav>
  <div class="container nav-inner">
    <a href="/" class="nav-logo" aria-label="DVT home">
      <!-- Inline logo SVG: bars mark + dvt wordmark -->
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 64" fill="none" height="32" aria-hidden="true">
        <polygon points="3,61 15,61 15,38 3,46" fill="#5BBFBA"/>
        <polygon points="19,61 33,61 33,23 19,31" fill="#5BBFBA"/>
        <polygon points="37,61 55,61 55,5 37,13" fill="#5BBFBA"/>
        <text
          x="71" y="48"
          font-family="Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
          font-weight="700" font-size="44" letter-spacing="-0.5"
          fill="#16263A"
        >dvt</text>
      </svg>
    </a>

    <div class="nav-actions">
      <a
        href="https://github.com/getdvt/dvt"
        class="btn-github"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Star DVT on GitHub"
      >
        <svg height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
        </svg>
        Star on GitHub
      </a>
    </div>
  </div>
</nav>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-neutral-200);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    color: inherit;
    transition: opacity var(--transition-fast);
  }
  .nav-logo:hover {
    opacity: 0.8;
    color: inherit;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .btn-github {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background: var(--color-neutral-950);
    color: var(--color-white);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: 500;
    transition: background var(--transition-fast), color var(--transition-fast);
  }
  .btn-github:hover {
    background: var(--color-neutral-700);
    color: var(--color-white);
  }
</style>
