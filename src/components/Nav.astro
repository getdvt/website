---
const { pathname } = Astro.url;
---

<nav>
  <div class="container nav-inner">
    <a href="/" class="nav-logo" aria-label="dvt home">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 64" fill="none" height="32" aria-hidden="true">
        <polygon points="3,61 15,61 15,38 3,46" fill="#5BBFBA"/>
        <polygon points="19,61 33,61 33,23 19,31" fill="#5BBFBA"/>
        <polygon points="37,61 55,61 55,5 37,13" fill="#5BBFBA"/>
        <text
          x="71" y="48"
          font-family="Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
          font-weight="700" font-size="44" letter-spacing="-0.5"
          fill="#16263A"
        >dvt</text>
      </svg>
    </a>

    <div class="nav-center">
      <a href="/vision"    class:list={['nav-link', { active: pathname === '/vision' }]}>Vision</a>
      <a href="/spec"      class:list={['nav-link', { active: pathname === '/spec'   }]}>Spec</a>
      <a href="/product"   class:list={['nav-link', { active: pathname === '/product' }]}>Product</a>
      <a href="/quickstart" class:list={['nav-link', { active: pathname === '/quickstart' }]}>Quickstart</a>
      <a href="/blog"      class:list={['nav-link', { active: pathname.startsWith('/blog') }]}>Blog</a>
      <a href="https://demo.dvt.dev/builder" class="nav-link">Builder</a>
    </div>

    <div class="nav-actions">
      <a href="/#early-access" class="btn-access">Get early access</a>
    </div>
  </div>
</nav>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-neutral-200);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
    gap: var(--space-6);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    color: inherit;
    transition: opacity var(--transition-fast);
  }
  .nav-logo:hover { opacity: 0.8; color: inherit; }

  .nav-center {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex: 1;
    /* Scroll the menu row rather than let it widen the page. min-width:0 releases
       the flexbox default min-width:auto so this flex item can shrink below its
       content width; overflow-x:auto then scrolls internally when cramped (mobile)
       and is inert when the links fit (desktop) — no breakpoint dead-band. */
    min-width: 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch; /* momentum scroll on iOS */
    overscroll-behavior-x: contain;    /* don't chain the swipe up to the page */
    scrollbar-width: none;             /* Firefox: hide the bar */
  }
  .nav-center::-webkit-scrollbar { display: none; } /* WebKit/Blink: hide the bar */

  .nav-link {
    flex-shrink: 0;      /* keep links full width so the row scrolls, not the links */
    white-space: nowrap;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-neutral-500);
    transition: color var(--transition-fast);
  }
  .nav-link:hover, .nav-link.active {
    color: var(--color-neutral-900);
  }

  .nav-actions { flex-shrink: 0; }

  .btn-access {
    display: inline-flex;
    align-items: center;
    padding: 8px var(--space-4);
    background: var(--color-brand-indigo);
    color: var(--color-white);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: 600;
    transition: background var(--transition-fast);
    white-space: nowrap;
  }
  .btn-access:hover {
    background: var(--color-brand-indigo-dark);
    color: var(--color-white);
  }

  @media (max-width: 768px) {
    /* Two rows: logo + CTA on top, the menu links on their own full-width row
       below. Squeezing the links between the logo and the button left them a
       ~130px sliver that scrolled one item at a time; a full-width second row
       gives them the whole viewport (fits without scrolling on most phones, and
       the .nav-center scroll container above still handles the narrowest ones). */
    .nav-inner {
      flex-wrap: wrap;
      height: auto;
      row-gap: var(--space-2);
      column-gap: var(--space-4);
      padding-block: var(--space-3);
    }
    .nav-logo    { order: 1; }
    .nav-actions { order: 2; } /* space-between keeps logo left, CTA right on row 1 */
    .nav-center {
      order: 3;
      flex-basis: 100%;         /* wrap onto a full-width second row */
      gap: var(--space-5);
      justify-content: flex-start; /* safe with overflow-x scroll on tiny screens */
    }
  }
</style>
