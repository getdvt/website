---
/**
 * Faithful static mockup of the in-app Dashboard History pane
 * (web/src/components/DashboardHistoryPane.tsx) — Activity tab: agent/human
 * entries with attribution ("· via dvt-claude"), a quoted change note, a
 * before→after revision-thumbnail pair with a Compare link, and a timestamp.
 * Names + dashboard renders are fabricated (no real person, no real data).
 */
import MiniDash from './MiniDash.astro';

const entries = [
  {
    agent: true,
    name: 'Maya Chen',
    via: 'dvt-claude',
    note: 'Reworded the territory map legend endpoints for scannability (Top/Floor prefixes).',
    revA: 'REV 8*', revB: 'REV 11', layout: 'map' as const,
    when: '1d ago · 21:36 Jul 16',
  },
  {
    agent: false,
    name: 'Devin Ross',
    initials: 'DR',
    via: null,
    note: 'Softened the referral-network SMB nodes from red to emerald — red was reading as an alert state on the flows page.',
    revA: 'REV 6*', revB: 'REV 10', layout: 'flows' as const,
    when: '1d ago · 21:21 Jul 16',
  },
];
---

<div class="vh" role="img" aria-label="dvt Dashboard History pane, Activity tab: revision entries with before and after dashboard thumbnails and a Compare link">
  <div class="vh-head">
    <span class="vh-title">History</span>
    <div class="vh-tabs">
      <span class="vh-tab active">Activity</span>
      <span class="vh-tab">Versions</span>
    </div>
    <span class="vh-close" aria-hidden="true">×</span>
  </div>

  <ul class="vh-list">
    {entries.map((e) => (
      <li class="vh-entry">
        <div class="vh-by">
          {e.agent ? (
            <span class="vh-av agent" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="15" height="15" fill="none">
                <rect x="5" y="8" width="14" height="11" rx="3" fill="#fff" />
                <rect x="9.2" y="11.4" width="2.2" height="2.6" rx="1" fill="#0D9488" />
                <rect x="12.6" y="11.4" width="2.2" height="2.6" rx="1" fill="#0D9488" />
                <path d="M12 4v3" stroke="#fff" stroke-width="1.6" stroke-linecap="round" />
                <circle cx="12" cy="3.4" r="1.4" fill="#fff" />
              </svg>
            </span>
          ) : (
            <span class="vh-av human" aria-hidden="true">{e.initials}</span>
          )}
          <span class="vh-meta">
            <strong>{e.name}</strong> updated dashboard
            {e.via && <span class="vh-via"> · via {e.via}</span>}
          </span>
        </div>

        <p class="vh-note">"{e.note}"</p>

        <div class="vh-diff">
          <figure class="vh-thumb">
            <figcaption>{e.revA}</figcaption>
            <MiniDash rev={e.revA} layout={e.layout} state="before" />
          </figure>
          <span class="vh-arrow" aria-hidden="true">→</span>
          <figure class="vh-thumb">
            <figcaption>{e.revB}</figcaption>
            <MiniDash rev={e.revB} layout={e.layout} state="after" />
          </figure>
        </div>

        <span class="vh-compare">
          <svg viewBox="0 0 16 16" width="12" height="12" fill="none" aria-hidden="true">
            <circle cx="7" cy="7" r="4.2" stroke="currentColor" stroke-width="1.4" />
            <path d="M10.4 10.4L14 14" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
          </svg>
          Compare
        </span>
        <span class="vh-when">{e.when}</span>
      </li>
    ))}
  </ul>
</div>

<style>
  .vh {
    background: var(--color-white);
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    font-size: var(--text-sm);
  }
  .vh-head {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4);
    border-bottom: 1px solid var(--color-neutral-200);
  }
  .vh-title {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-neutral-900);
  }
  .vh-tabs { display: flex; gap: 6px; }
  .vh-tab {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-neutral-500);
    padding: 3px 10px;
    border-radius: 999px;
  }
  .vh-tab.active {
    color: var(--color-brand-indigo);
    background: rgba(79, 70, 229, 0.1);
  }
  .vh-close { margin-left: auto; color: var(--color-neutral-400); font-size: var(--text-lg); line-height: 1; }

  .vh-list { list-style: none; margin: 0; padding: 0; }
  .vh-entry {
    padding: var(--space-4);
    border-bottom: 1px solid var(--color-neutral-100);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .vh-entry:last-child { border-bottom: none; }

  .vh-by { display: flex; align-items: center; gap: var(--space-3); }
  .vh-av {
    flex-shrink: 0;
    width: 28px; height: 28px;
    border-radius: var(--radius-md);
    display: flex; align-items: center; justify-content: center;
  }
  .vh-av.agent { background: var(--color-brand-teal); }
  .vh-av.human {
    border-radius: 50%;
    background: var(--color-neutral-200);
    color: var(--color-neutral-700);
    font-size: 10px;
    font-weight: 700;
  }
  .vh-meta { color: var(--color-neutral-600); line-height: 1.4; }
  .vh-meta strong { color: var(--color-neutral-900); font-weight: 700; }
  .vh-via { color: var(--color-neutral-400); }

  .vh-note {
    color: var(--color-neutral-700);
    line-height: 1.5;
    margin: 0;
  }

  .vh-diff {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-2);
  }
  .vh-thumb {
    margin: 0;
    border: 1px solid var(--color-neutral-200);
    border-radius: var(--radius-md);
    padding: 6px;
    background: var(--color-white);
  }
  .vh-thumb figcaption {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-neutral-400);
    margin-bottom: 5px;
  }
  .minidash { display: block; width: 100%; height: auto; border-radius: var(--radius-sm); }
  .vh-arrow { color: var(--color-neutral-400); font-size: var(--text-sm); }

  .vh-compare {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-brand-indigo);
  }
  .vh-when { font-size: var(--text-xs); color: var(--color-neutral-400); }
</style>
